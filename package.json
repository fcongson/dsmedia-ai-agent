{
  "name": "dsmedia-ai-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cli": "node --import tsx src/cli.ts",
    "ingest": "node --import tsx src/ingest.ts",
    "ingest_video": "node --import tsx src/cli.ts ingest_video",
