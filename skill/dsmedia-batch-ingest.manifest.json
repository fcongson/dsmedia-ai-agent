{
  "id": "dsmedia-batch-ingest",
  "name": "DS.media Batch Ingest",
  "description": "Batch ingest guidance for playlists, channels, and URL lists using shared MCP and CLI operations.",
  "supportedTools": [
    "parse_video_id",
    "download_audio",
    "fetch_description",
    "write_video_summary",
    "fetch_subtitles",
    "transcribe_audio",
    "analyse_transcript",
    "expand_playlist"
  ],
  "supportedCommands": [
    "ingest_batch",
    "parse_video_id",
    "download_audio",
    "fetch_description",
    "write_video_summary",
    "fetch_subtitles",
    "transcribe_audio",
    "analyse_transcript",
    "expand_playlist"
  ],
  "artifacts": [
    "data/audio/<videoId>.mp3",
    "data/descriptions/<videoId>.txt",
    "data/metadata/<videoId>.json",
    "data/notes/<videoId>.md",
    "data/transcripts/<videoId>.txt",
    "data/analysis/<videoId>.json"
  ],
  "defaults": {
    "llmProfile": "balanced",
    "transcriptStrategy": "subtitle-first with Whisper fallback"
  },
  "portabilityTargets": [
    "claude-desktop",
    "codex",
    "open-webui",
    "generic-mcp-client"
  ]
}
